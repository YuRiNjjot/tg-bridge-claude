# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ═══════════════════════════════════════════════════
# AI ПРОВАЙДЕРЫ (fallback chain)
# ═══════════════════════════════════════════════════

# Primary: Groq (быстрый, дешевый)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Fallback 1: OpenRouter (много бесплатных моделей)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free

# Fallback 2: Ollama (локальный)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=kimi-k2.6:cloud

# ═══════════════════════════════════════════════════
# ГОЛОСОВЫЕ СООБЩЕНИЯ (Voice → Text)
# ═══════════════════════════════════════════════════

# Выберите бэкенд:
# "local"   — локальный whisper.cpp (работает на GPU AMD через Vulkan)
# "openai"  — OpenAI Whisper API (cloud, платно)
# "disabled" — не обрабатывать голосовые
WHISPER_BACKEND=local

# Пути для локального whisper (только если WHISPER_BACKEND=local)
# Для AMD GPU через Vulkan + Windows exe (WSL2):
WHISPER_WINDOWS_EXE=D:\\ai\\audio-text\\whisper-vulkan\\whisper-cli.exe
WHISPER_WINDOWS_MODEL=D:\\AI\\hermes\\whisper-bin\\ggml-small.bin
WHISPER_WINDOWS_TEMP=D:\\tmp\\tg-claude

# Для NVIDIA GPU или CPU через Linux build:
# WHISPER_LINUX_EXE=/mnt/e/ClaudeCode/whisper-vulkan/build_cpu/bin/whisper-cli
# WHISPER_LINUX_MODEL=/mnt/e/ClaudeCode/whisper-vulkan/models/for-tests-ggml-small.bin

# OpenAI API Key (нужен только если WHISPER_BACKEND=openai)
OPENAI_API_KEY=

# ═══════════════════════════════════════════════════
# ВИДЕНИЕ (Photo → Description)
# ═══════════════════════════════════════════════════

# Выберите бэкенд:
# "ollama"   — локальная модель через Ollama (llava, moondream и др.)
# "anthropic" — Claude Vision API (cloud, платно)
# "openai"    — GPT-4 Vision (cloud, платно)
# "disabled"  — не обрабатывать фото
VISION_BACKEND=ollama

# Модель для Ollama vision (только если VISION_BACKEND=ollama)
# Популярные модели:
#   llava       — базовая vision (7B)
#   bakllava    — улучшенная vision (7B)
#   moondream   — очень быстрая (1.6B)
VISION_OLLAMA_MODEL=llava

# ═══════════════════════════════════════════════════
# ОБЩИЕ НАСТРОЙКИ
# ═══════════════════════════════════════════════════

# Максимум сообщений в контексте
MAX_CONTEXT_MESSAGES=20

# ID администратора (ваш Telegram ID)
ADMIN_TG_ID=your_telegram_user_id_here
