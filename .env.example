# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ═══════════════════════════════════════════════════
# ГОЛОСОВЫЕ СООБЩЕНИЯ (Voice → Text)
# ═══════════════════════════════════════════════════

# Выберите бэкенд:
# "local"   — локальный whisper.cpp (работает на GPU AMD через Vulkan)
# "openai"  — OpenAI Whisper API (cloud, платно)
# "disabled" — не обрабатывать голосовые
WHISPER_BACKEND=local

# Пути для локального whisper (относительно папки репозитория)
# whisper-cli.exe уже в bin/, модель скачается setup_whisper.ps1
WHISPER_WINDOWS_EXE=.\bin\whisper-cli.exe
WHISPER_WINDOWS_MODEL=.\models\ggml-small.bin
WHISPER_WINDOWS_TEMP=.\data\temp

# ═══════════════════════════════════════════════════
# ВИДЕНИЕ (Photo → Description)
# ═══════════════════════════════════════════════════

# Bridge не делает AI-описание фото. Описание — задача Claude Code.
VISION_BACKEND=disabled

# ═══════════════════════════════════════════════════
# ОБЩИЕ НАСТРОЙКИ
# ═══════════════════════════════════════════════════

# Максимум сообщений в контексте
MAX_CONTEXT_MESSAGES=20

# ID администратора (ваш Telegram ID)
ADMIN_TG_ID=your_telegram_user_id_here
